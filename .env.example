# ─── GymFlow Gestor — Variáveis de Ambiente ─────────────────────────────────
# Copie este arquivo para .env e preencha os valores

# ─── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gymflow?sslmode=require"
REDIS_URL="redis://default:PASSWORD@HOST:6379"

# ─── SUPABASE ───────────────────────────────────────────────────────────────
SUPABASE_URL="https://XXXXX.supabase.co"
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI..."   # service_role key (backend)
SUPABASE_JWT_SECRET="seu-jwt-secret-do-supabase"

# ─── APP ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
JWT_SECRET="minimo-32-caracteres-super-secreto!!"
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# ─── PIX — EFÍ BANK ─────────────────────────────────────────────────────────
EFI_CLIENT_ID="Client_Id_XXXXXXXXXX"
EFI_CLIENT_SECRET="Client_Secret_XXXXXXXXXX"
EFI_SANDBOX="true"                                        # false em produção
PIX_CHAVE="seu-email@academia.com.br"                     # ou CPF/CNPJ/telefone

# ─── WHATSAPP — EVOLUTION API ────────────────────────────────────────────────
EVOLUTION_API_URL="https://evolution.seudominio.com.br"
EVOLUTION_API_KEY="sua-api-key-evolution"
EVOLUTION_INSTANCE="gymflow"

# ─── AWS (biometria + storage) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_REGION="us-east-1"
AWS_REKOGNITION_COLLECTION="gymflow-faces"
AWS_S3_BUCKET="gymflow-uploads"
AWS_CLOUDFRONT_URL="https://cdn.gymflowgestor.com.br"

# ─── EMAIL — RESEND ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXXXXXXXXXX"
EMAIL_FROM="GymFlow Gestor <noreply@gymflowgestor.com.br>"

# ─── AGENDAMENTOS (lead capture demo-first) ─────────────────────────────────
ADMIN_LEAD_EMAIL="fjntecnologia2022@gmail.com"          # destino do email "novo lead"
ADMIN_LEAD_WHATSAPP="5565996952828"                     # idem, via WhatsApp bridge (opcional)

# ─── STRIPE (cartão recorrente) ──────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXX"
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXX"

# ─── MONITORAMENTO ───────────────────────────────────────────────────────────
SENTRY_DSN="https://XXXXX@oXXXXX.ingest.sentry.io/XXXXX"
