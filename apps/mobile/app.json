{
  "expo": {
    "name": "GymFlow Gestor para Alunos",
    "slug": "gymflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gymflow",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fjntecnologia.gymflowgestor"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08080F"
      },
      "package": "com.fjntecnologia.gymflowgestor",
      "compileSdkVersion": 34,
      "targetSdkVersion": 35,
      "buildToolsVersion": "35.0.0",
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#08080F",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00E5FF"
        }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
