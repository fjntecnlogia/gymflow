generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ACADEMIA (Tenant Root) ────────────────────────────

model Academia {
  id            String         @id @default(cuid())
  nome          String
  cnpj          String?        @unique
  telefone      String?
  email         String         @unique
  slug          String         @unique
  logoUrl       String?
  endereco      Json?
  configuracoes Json           @default("{}")
  planoSaas     PlanoSaas      @default(STARTER)
  status        StatusAcademia @default(TRIAL)
  trialExpiraEm DateTime?
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt

  usuarios       Usuario[]
  alunos         Aluno[]
  planos         Plano[]
  matriculas     Matricula[]
  acessos        RegistroAcesso[]
  pagamentos     Pagamento[]
  catracas       Catraca[]
  notificacoes   NotificacaoLog[]
  faceEmbeddings FaceEmbedding[]

  @@map("academias")
}

enum PlanoSaas {
  STARTER
  PRO
  ENTERPRISE
}

enum StatusAcademia {
  TRIAL
  ATIVO
  INADIMPLENTE
  CANCELADO
}

// ─── USUARIOS (Dono / Staff) ──────────────────────────

model Usuario {
  id           String      @id @default(cuid())
  academiaId   String
  // Nullable pra retro-compat com cadastros antigos via Supabase Auth.
  // Novos usuários usam auth próprio (senhaHash + JWT do backend Fastify).
  supabaseId   String?     @unique
  nome         String
  email        String
  telefone     String?
  role         RoleUsuario @default(STAFF)
  ativo        Boolean     @default(true)

  // ─── Auth próprio (Postgres + bcrypt + JWT) ────────────────────
  senhaHash                 String?
  tokenPrimeiroAcesso       String?   @unique
  tokenPrimeiroAcessoExpira DateTime?
  tokenResetSenha           String?   @unique
  tokenResetSenhaExpira     DateTime?
  ultimoLoginEm             DateTime?

  // ─── Onboarding (tutorial primeira vez) ────────────────────────
  onboardingConcluido       Boolean   @default(false)
  onboardingConcluidoEm     DateTime?

  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt

  academia Academia @relation(fields: [academiaId], references: [id], onDelete: Cascade)

  @@unique([academiaId, email])
  @@map("usuarios")
}

enum RoleUsuario {
  SUPER_ADMIN
  DONO
  GERENTE
  STAFF
}

// ─── ALUNOS ────────────────────────────────────────────

model Aluno {
  id             String      @id @default(cuid())
  academiaId     String
  supabaseId     String?     @unique
  nome           String
  email          String?
  telefone       String
  cpf            String?
  dataNascimento DateTime?
  fotoUrl        String?
  faceId         String?
  qrCodeToken    String      @unique @default(cuid())
  status         StatusAluno @default(ATIVO)
  observacoes    String?
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  faceRegistrada Boolean @default(false)

  academia      Academia         @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  matriculas    Matricula[]
  acessos       RegistroAcesso[]
  pagamentos    Pagamento[]
  faceEmbedding FaceEmbedding?

  @@unique([academiaId, email])
  @@index([academiaId, status])
  @@map("alunos")
}

enum StatusAluno {
  ATIVO
  INADIMPLENTE
  SUSPENSO
  CANCELADO
}

// ─── PLANOS ────────────────────────────────────────────

model Plano {
  id              String    @id @default(cuid())
  academiaId      String
  nome            String
  descricao       String?
  valor           Decimal   @db.Decimal(10, 2)
  duracaoDias     Int
  tipo            TipoPlano @default(MENSAL)
  ativo           Boolean   @default(true)
  permiteCongelar Boolean   @default(false)
  limiteTreinos   Int?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  academia   Academia    @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  matriculas Matricula[]

  @@map("planos")
}

enum TipoPlano {
  DIARIO
  SEMANAL
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

// ─── MATRICULAS ────────────────────────────────────────

model Matricula {
  id             String          @id @default(cuid())
  academiaId     String
  alunoId        String
  planoId        String
  dataInicio     DateTime
  dataVencimento DateTime
  dataRenovacao  DateTime?
  valorPago      Decimal         @db.Decimal(10, 2)
  status         StatusMatricula @default(ATIVA)
  observacoes    String?
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt

  academia   Academia    @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  aluno      Aluno       @relation(fields: [alunoId], references: [id])
  plano      Plano       @relation(fields: [planoId], references: [id])
  pagamentos Pagamento[]

  @@index([academiaId, status])
  @@index([academiaId, dataVencimento])
  @@map("matriculas")
}

enum StatusMatricula {
  ATIVA
  VENCIDA
  CANCELADA
  CONGELADA
}

// ─── CATRACAS ──────────────────────────────────────────

model Catraca {
  id           String   @id @default(cuid())
  academiaId   String
  nome         String
  modelo       String   @default("GENERICO")
  ip           String
  apiKey       String
  ativa        Boolean  @default(true)
  ultimoStatus String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  academia Academia         @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  acessos  RegistroAcesso[]

  @@map("catracas")
}

// ─── REGISTROS DE ACESSO ──────────────────────────────

model RegistroAcesso {
  id             String          @id @default(cuid())
  academiaId     String
  alunoId        String
  catracaId      String?
  tipo           TipoAcesso      @default(QR_CODE)
  resultado      ResultadoAcesso
  motivoBloqueio String?
  ipDispositivo  String?
  criadoEm       DateTime        @default(now())

  academia Academia @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  aluno    Aluno    @relation(fields: [alunoId], references: [id])
  catraca  Catraca? @relation(fields: [catracaId], references: [id])

  @@index([academiaId, criadoEm])
  @@index([alunoId, criadoEm])
  @@index([academiaId, resultado])
  @@map("registros_acesso")
}

enum TipoAcesso {
  QR_CODE
  BIOMETRIA
  RFID
  MANUAL
  WEBHOOK
}

enum ResultadoAcesso {
  LIBERADO
  BLOQUEADO
}

// ─── PAGAMENTOS ────────────────────────────────────────

model Pagamento {
  id               String          @id @default(cuid())
  academiaId       String
  alunoId          String
  matriculaId      String?
  valor            Decimal         @db.Decimal(10, 2)
  metodo           MetodoPagamento
  status           StatusPagamento @default(PENDENTE)
  pixTxId          String?         @unique
  pixQrCode        String?
  pixLinkPagamento String?
  stripePaymentId  String?
  dataVencimento   DateTime
  dataPagamento    DateTime?
  descricao        String?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt

  academia  Academia   @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  aluno     Aluno      @relation(fields: [alunoId], references: [id])
  matricula Matricula? @relation(fields: [matriculaId], references: [id])

  @@index([academiaId, status])
  @@index([academiaId, dataVencimento])
  @@index([alunoId])
  @@map("pagamentos")
}

enum MetodoPagamento {
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  DINHEIRO
}

enum StatusPagamento {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
  ESTORNADO
}

// ─── NOTIFICACOES LOG ─────────────────────────────────

model NotificacaoLog {
  id           String            @id @default(cuid())
  academiaId   String
  alunoId      String?
  canal        CanalNotificacao
  tipo         String
  destinatario String
  mensagem     String
  status       StatusNotificacao @default(ENVIADO)
  erro         String?
  criadoEm     DateTime          @default(now())

  academia Academia @relation(fields: [academiaId], references: [id], onDelete: Cascade)

  @@index([academiaId, criadoEm])
  @@map("notificacoes_log")
}

enum CanalNotificacao {
  WHATSAPP
  EMAIL
  PUSH
  SMS
}

enum StatusNotificacao {
  ENVIADO
  ENTREGUE
  ERRO
}

// ─── WHATSAPP SESSION (Baileys auth state por academia) ────────────────
// ─── BIOMETRIA FACIAL ─────────────────────────────────

model FaceEmbedding {
  id           String   @id @default(cuid())
  alunoId      String   @unique
  academiaId   String
  embedding    String // JSON array de floats (vetor 512d)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno    Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  academia Academia @relation(fields: [academiaId], references: [id], onDelete: Cascade)

  @@index([academiaId])
  @@map("face_embeddings")
}

model WhatsappSession {
  academiaId   String
  key          String
  data         Json
  atualizadoEm DateTime @updatedAt

  @@id([academiaId, key])
  @@map("whatsapp_sessions")
}

// ─── AGENDAMENTOS (Leads de demonstração — fora do tenant) ─────────
// Recebe solicitações públicas de /agendar e alimenta /admin/agendamentos.
// NÃO tem academiaId — é lead, ainda não virou cliente.

model Agendamento {
  id               String            @id @default(cuid())
  nome             String
  telefone         String
  email            String?
  academiaNome     String
  cidade           String
  numAlunos        String // '0-50' | '50-200' | '200-500' | '500+'
  horarioPreferido String
  observacao       String?
  status           StatusAgendamento @default(PENDENTE)
  ipOrigem         String?
  contatadoEm      DateTime?
  convertidoEm     DateTime?
  criadoEm         DateTime          @default(now())
  atualizadoEm     DateTime          @updatedAt

  @@index([status, criadoEm])
  @@index([criadoEm])
  @@map("agendamentos")
}

enum StatusAgendamento {
  PENDENTE
  CONTATADO
  CONVERTIDO
  PERDIDO
}
